# Konfigurasi CKAN API untuk Portal Satu Data Kabupaten Lebong
# Salin file ini menjadi .env dan isi nilai yang sesuai

# URL instance CKAN (default: demo CKAN)
# Ganti dengan URL instance CKAN Kabupaten Lebong Anda
VITE_CKAN_BASE_URL=https://demo.ckan.org

# API Key CKAN (opsional, kosongkan untuk akses publik/anonim)
# Dapatkan dari User Profile > Manage > API tokens di instance CKAN Anda
# VITE_CKAN_API_KEY=your-api-key-here